# Copy this file to .env.development and .env.production, then fill in your values.
# NEVER commit .env.development or .env.production to git.
#
# Build modes: release builds load .env.production; debug/profile load
# .env.development (see lib/main.dart). Editing only .env.production does not
# affect debug runs on a device or emulator.

# Backend API base URL (include /api/v1)
API_BASE_URL=https://api.yourdomain.com/api/v1

# Socket.IO URL (no path)
SOCKET_URL=https://api.yourdomain.com

# Website base URL (for legal pages, etc.)
WEBSITE_BASE_URL=https://yourdomain.com

# Stream Chat/Video API key (public key, optional - has default)
# STREAM_API_KEY=your_stream_api_key

# Cloudflare Images pipeline feature flag.
# MUST match the backend USE_CLOUDFLARE_IMAGES value at all times — they are
# flipped together during cutover. When "false" or unset, the app keeps using
# legacy Firebase/string URL adapters and ignores Cloudflare ImageAsset fields.
USE_CLOUDFLARE_IMAGES=true

# Sentry error monitoring (org: yagati, project: flutter)
# Get DSN: Sentry → Settings → Projects → flutter → Client Keys (DSN)
# Release naming: matchvibe@{version}+{buildNumber} e.g. matchvibe@1.0.0+37
# CI override: --dart-define=SENTRY_DSN=https://...@....ingest....sentry.io/...
# Leave empty in .env.development so normal debug runs do not report.
SENTRY_DSN=

# Creator program WhatsApp (digits only, include country code — e.g. 919876543210).
# Used when users tap "Apply on WhatsApp" on the Become a Creator screen.
CREATOR_WHATSAPP_NUMBER=

# Optional performance trace sample rate (0.0–1.0). Default: 0.15 in release, 0.0 in debug.
# SENTRY_TRACES_SAMPLE_RATE=0.15

# CI symbol upload (not read by the Dart app — build pipeline / sentry-cli only):
# SENTRY_AUTH_TOKEN=...
# SENTRY_ORG=yagati
# SENTRY_PROJECT=flutter

# Verify setup in debug (optional): flutter run --dart-define=SENTRY_ALLOW_DEBUG_REPORTING=true
# (requires SENTRY_DSN in .env.development for that session only)

# Meta App Events (Android) — also set android/facebook.properties for native SDK
META_APP_ID=
META_CLIENT_TOKEN=
# Test in debug: flutter run --dart-define=META_ALLOW_DEBUG_EVENTS=true
# Verbose SDK logs: --dart-define=META_APP_EVENTS_DEBUG=true
