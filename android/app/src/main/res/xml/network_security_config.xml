<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Trust Railway's SSL certificates -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">vibemeet-backend-production.up.railway.app</domain>
        <domain includeSubdomains="true">*.up.railway.app</domain>
        <domain includeSubdomains="true">railway.app</domain>
        <trust-anchors>
            <!-- Trust system certificates (Railway uses valid SSL certs) -->
            <certificates src="system" />
            <!-- Also trust user certificates for debugging (optional) -->
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    
    <!-- Default configuration for all other domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
