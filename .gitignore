/macos/Flutter/ephemeral/
/macos/Pods/

# Linux build artifacts
/linux/flutter/ephemeral/

# Large media files - ignore most PNGs but keep essential app icons
# Ignore all PNGs by default
*.png
# But keep essential app icons, favicons, and web icons
!android/app/src/main/res/**/ic_launcher.png
!ios/Runner/Assets.xcassets/**/*.png
!macos/Runner/Assets.xcassets/**/*.png
!web/icons/*.png
!web/favicon.png

# Ignore large image and media files in assets
/lib/assets/**/*.jpg
/lib/assets/**/*.jpeg
/lib/assets/**/*.mp3
/lib/assets/**/*.mp4
/lib/assets/**/*.mov
/lib/assets/**/*.avi
/lib/assets/**/*.wav

# Keystore files (security sensitive)
**/*.keystore
**/*.jks
**/key.properties
**/google-services.json

# Environment files (never commit secrets)
.env
.env.*
!.env.example

# Gradle wrapper JAR (should be downloaded, not committed)
/android/gradle/wrapper/gradle-wrapper.jar

# Lock files (optional - some teams commit these)
# pubspec.lock

# Generated files
*.g.dart
*.freezed.dart
*.config.dart
firebase_options.dart
